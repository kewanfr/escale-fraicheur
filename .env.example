# Frontend. Laisser vide pour lancer immédiatement en mode démonstration.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optionnel. Clé publique Cloudflare Turnstile.
VITE_TURNSTILE_SITE_KEY=

# / pour un domaine personnalisé ou un site utilisateur GitHub Pages.
# /nom-du-repo/ pour un site projet GitHub Pages.
VITE_BASE_PATH=/
